# Window Focus
shift + alt - j : yabai -m window --focus south
shift + alt - k : yabai -m window --focus north
shift + alt - h : yabai -m window --focus west
shift + alt - l : yabai -m window --focus east

# Window Swap
ctrl + shift + alt - j : yabai -m window --swap south
ctrl + shift + alt - k : yabai -m window --swap north 
ctrl + shift + alt - h : yabai -m window --swap west
ctrl + shift + alt - l : yabai -m window --swap east

# Focus Space
ctrl - right : yabai -m space --focus next
ctrl - left : yabai -m space --focus prev
ctrl - 0x12 : yabai -m space --focus 1
ctrl - 0x13 : yabai -m space --focus 2
ctrl - 0x14 : yabai -m space --focus 3
ctrl - 0x15 : yabai -m space --focus 4
ctrl - 0x17 : yabai -m space --focus 5
ctrl - 0x16 : yabai -m space --focus 6

# Throw window to space
ctrl + shift - left : yabai -m window --space prev
ctrl + shift - right : yabai -m window --space next
ctrl + shift - 0x12 : yabai -m window --space 1
ctrl + shift - 0x13 : yabai -m window --space 2
ctrl + shift - 0x14 : yabai -m window --space 3
ctrl + shift - 0x15 : yabai -m window --space 4
ctrl + shift - 0x17 : yabai -m window --space 5
ctrl + shift - 0x16 : yabai -m window --space 6

# Throw window to space & focus space
ctrl + shift + alt - left : yabai -m window --space prev && yabai -m space --focus prev
ctrl + shift + alt - right : yabai -m window --space next && yabai -m space --focus next
ctrl + shift + alt - 0x12 : yabai -m window --space 1 && yabai -m space --focus 1
ctrl + shift + alt - 0x13 : yabai -m window --space 2 && yabai -m space --focus 2 
ctrl + shift + alt - 0x14 : yabai -m window --space 3 && yabai -m space --focus 3 
ctrl + shift + alt - 0x15 : yabai -m window --space 4 && yabai -m space --focus 4
ctrl + shift + alt - 0x17 : yabai -m window --space 5 && yabai -m space --focus 5
ctrl + shift + alt - 0x16 : yabai -m window --space 6 && yabai -m space --focus 6

# Focus Displays
ctrl + alt - 0x1E : yabai -m display --focus prev
ctrl + alt - 0x21 : yabai -m display --focus next

# Throw window to display
ctrl + alt + shift - 0x1E : yabai -m window --display prev
ctrl + alt + shift - 0x21 : yabai -m window --display next

# Zoom
alt + shift - f : yabai -m window --toggle zoom-parent
ctrl + alt + shift - f : yabai -m window --toggle zoom-fullscreen

# Toggle Float
ctrl + alt + shift - t : yabai -m window --toggle float

# Toggle Sticky
ctrl + alt + shift - s : yabai -m window --toggle sticky

# Open Terminal
ctrl + alt + shift - return : /Applications/WezTerm.app/Contents/MacOS/wezterm

# Restart yabai
ctrl + alt + shift - z : yabai --restart-service
